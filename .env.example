# Solana devnet only — app is configured for Solana devnet
# Solana Network (must be devnet)
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Solana devnet RPC (MagicBlock router recommended)
NEXT_PUBLIC_SOLANA_RPC_ENDPOINT=https://devnet-router.magicblock.app

# Treasury Configuration
NEXT_PUBLIC_TREASURY_ADDRESS=YourSolanaTreasuryPubkeyHere
SOLANA_TREASURY_SECRET_KEY=your-treasury-secret-key

# Application Configuration
NEXT_PUBLIC_APP_NAME=Solnomo
NEXT_PUBLIC_ROUND_DURATION=30
NEXT_PUBLIC_PRICE_UPDATE_INTERVAL=1000
NEXT_PUBLIC_CHART_TIME_WINDOW=300000

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
