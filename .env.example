# =============================================================================
# SUI BLOCKCHAIN CONFIGURATION
# =============================================================================

# Sui Network
# Options: testnet, mainnet, devnet, localnet
# Use 'testnet' for testing, 'mainnet' for production
NEXT_PUBLIC_SUI_NETWORK=testnet

# Sui RPC Endpoint
# The RPC endpoint URL for connecting to the Sui blockchain
# Testnet: https://fullnode.testnet.sui.io:443
# Mainnet: https://fullnode.mainnet.sui.io:443
# Devnet: https://fullnode.devnet.sui.io:443
NEXT_PUBLIC_SUI_RPC_ENDPOINT=https://fullnode.testnet.sui.io:443

# =============================================================================
# TREASURY CONTRACT CONFIGURATION
# =============================================================================

# Treasury Package ID
# The package ID of the deployed treasury contract on Sui
# This is obtained when you publish the contract using 'sui client publish'
NEXT_PUBLIC_TREASURY_PACKAGE_ID=0xbd4e8f5d340223fc9907b5cf1f5cc0a739c888f8e71aa299adc6b1f0404ba016

# Treasury Object ID
# The shared object ID of the treasury instance
# This is obtained when you create a treasury using the 'create_treasury' function
NEXT_PUBLIC_TREASURY_OBJECT_ID=0x230234815eb4ad1cb8ea1efe80515c5e0c825c6c98b618156ae8502bba12bc1c

# USDC Token Type
# The full type identifier for USDC on Sui
# Format: 0x<package_id>::<module>::<type>
# Sui testnet USDC: 0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC
NEXT_PUBLIC_USDC_TYPE=0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================

# Supabase Project URL
# Get this from your Supabase project dashboard:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy the "Project URL" (e.g., https://abcdefghijklmnop.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Supabase Anonymous Key
# Get this from your Supabase project dashboard:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy the "anon public" key from "Project API keys"
# This key is safe to use in client-side code
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application Name
# The name of your application (displayed in UI)
NEXT_PUBLIC_APP_NAME=Overflow

# Round Duration
# Duration of each betting round in seconds
# Default: 30 seconds
NEXT_PUBLIC_ROUND_DURATION=30

# Price Update Interval
# How often to fetch BTC price updates in milliseconds
# Default: 1000ms (1 second)
NEXT_PUBLIC_PRICE_UPDATE_INTERVAL=1000

# Chart Time Window
# Time window for the price chart in milliseconds
# Default: 300000ms (5 minutes)
NEXT_PUBLIC_CHART_TIME_WINDOW=300000
